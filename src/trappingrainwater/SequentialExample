import java.util.List;

public class SequentialExample {

    public static void main(String[] args) {
        long startTime = System.currentTimeMillis();

        User user = getUserFromRemoteService(1);
        List<Order> orders = getOrdersFromRemoteService(1);

        long endTime = System.currentTimeMillis();

        System.out.println("user = " + user);
        System.out.println("orders = " + orders);
        System.out.println("total time = " + (endTime - startTime) + " ms");
    }

    static User getUserFromRemoteService(int userId) {
        System.out.println("Start get user, thread = " + Thread.currentThread().getName());

        sleep(2000);

        System.out.println("End get user");

        return new User(userId, "Alex");
    }

    static List<Order> getOrdersFromRemoteService(int userId) {
        System.out.println("Start get orders, thread = " + Thread.currentThread().getName());

        sleep(2000);

        System.out.println("End get orders");

        return List.of(
                new Order(101, userId, "Book"),
                new Order(102, userId, "Mouse")
        );
    }

    static void sleep(long millis) {
        try {
            Thread.sleep(millis);
        } catch (InterruptedException exception) {
            Thread.currentThread().interrupt();
            throw new RuntimeException(exception);
        }
    }
}

record User(int id, String name) {
}

record Order(int id, int userId, String item) {
}
